# Ledgerly — portable profile for Dell XPS 15 9530 (Dad's PC)
# Copy to .env after Setup.bat:  copy .env.portable-xps15.example .env
# See docs/target-pc-dad-xps15.md

LEDGERLY_PROFILE=portable

# Smaller models (omit LLM_MODEL / LLAVA_MODEL — app/config.py picks qwen2.5:3b + moondream)

# Thermal / pacing (Docker Ollama runs on CPU in the VM — RTX 4060 not used by default)
OLLAMA_NUM_THREADS=4
OLLAMA_MAX_CONCURRENT=1
LLM_INTER_CALL_SLEEP_SEC=2
ASK_QUEUE_INTER_JOB_SLEEP_SEC=5
INGEST_QUEUE_INTER_JOB_SLEEP_SEC=3
OLLAMA_WARMUP_ENABLED=false

# Embeddings (required for ingest + Ask)
EMBED_MODEL=nomic-embed-text
